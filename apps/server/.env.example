# Anact Ortho backend — environment configuration
# All values are OPTIONAL. The server runs fully without any of them.

# Port the API listens on (default 8787).
PORT=8787

# --- Optional LLM enhancement --------------------------------------------
# Drop an OpenAI key here to upgrade commentary + scouting reports from the
# built-in deterministic engine to model-generated text. Leave blank to stay
# 100% offline (the product still works end-to-end).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
