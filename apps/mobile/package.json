    "@shopify/react-native-skia": "^1.5.0",
    "expo": "~51.0.28",
    "expo-av": "~14.0.7",
    "expo-constants": "~16.0.2",
    "expo-dev-client": "~4.0.25",
    "expo-file-system": "~17.0.1",
    "expo-linking": "~6.3.1",
    "expo-router": "~3.5.23",
    "expo-speech": "~12.0.2",
